# ═══════════════════════════════════════════════════════════════════
# Backend PaieCashCoin — env vars
# Copier en `.env` (gitignoré) et remplir au minimum les vars 🔴
# ═══════════════════════════════════════════════════════════════════

# ─── 🔴 OBLIGATOIRE pour démarrer ──────────────────────────────────
PORT=3001
JWT_SECRET=                      # généré : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPABASE_URL=                    # ex: https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=       # depuis Supabase Dashboard > Project Settings > API > service_role
FRONTEND_URL=http://localhost:5174

# ─── 🟡 OPTIONNEL — Circle wallet (provision auto à l'inscription) ─
# Si non rempli : /api/v2/mint/auth/register crashera (création de wallet)
# Tu peux quand même démarrer le serveur sans ces clés et tester les
# autres endpoints. Demande à l'équipe Frostrek les clés de dev.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
WALLET_SET_ID=
ADMIN_WALLET_ID=
ADMIN_WALLET_ADDRESS=
TREASURY_WALLET_ADDRESS=
BETTING_WALLET_ID=
BETTING_WALLET_ADDRESS=

# ─── 🟡 OPTIONNEL — On-chain config (smart contracts) ──────────────
BLOCKCHAIN=polygon-amoy           # ou 'matic' pour mainnet
ADMIN_ADDRESS=
PCC_CONTRACT_ADDRESS=
EURC_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ─── 🟡 OPTIONNEL — Rampes fiat (skip en dev sauf si testé) ────────
# Stripe (carte bancaire)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# MoonPay
MOONPAY_API_KEY=
MOONPAY_PUBLISHABLE_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=
MOONPAY_ENVIRONMENT=sandbox       # ou 'production'
# Transak
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_WEBHOOK_SECRET=
TRANSAK_ENVIRONMENT=STAGING       # ou 'PRODUCTION'

# ─── 🟡 OPTIONNEL — Crypto gateway routing ─────────────────────────
CRYPTO_GATEWAY_PRIMARY=transak
CRYPTO_GATEWAY_FALLBACK=moonpay

# ─── 🟡 OPTIONNEL — Données foot externes (TheSportsDB) ────────────
THESPORTSDB_KEY=
THESPORTSDB_BASE=https://www.thesportsdb.com/api/v1/json

# ─── 🟡 OPTIONNEL — Betting reward config ──────────────────────────
PREDICTION_REWARD_PCC=10

# API-Football (api-football.com) — import clubs/joueurs
API_FOOTBALL_KEY=
