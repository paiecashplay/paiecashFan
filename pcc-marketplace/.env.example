# ═══════════════════════════════════════════════════════════════════
# pcc-marketplace — env vars (frontend Vite)
# Copier en `.env` (gitignoré) et remplir.
# ═══════════════════════════════════════════════════════════════════

# URL du backend Node (Express) — en dev local : http://localhost:3001
# En prod : https://api.paiecashfan.com (à configurer en Sprint 2)
VITE_API_URL=http://localhost:3001

# Supabase (utilisé uniquement pour les Realtime subscriptions côté client,
# pas pour l'auth qui passe par /api/v2/mint/auth via le backend Express)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL de la page "Buy PCC" (achat de tokens) — externe au marketplace
# En dev : laisser vide, défaut = http://localhost:5173
# En prod : https://paiecashcoin.frostrek.com (ou ton URL équivalente)
VITE_MINT_URL=
