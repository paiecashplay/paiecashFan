# ═══════════════════════════════════════════════════════════════════
# paiecashfan-app — env vars (frontend Vite)
# Copier en `.env` (gitignoré) et remplir si besoin.
# ═══════════════════════════════════════════════════════════════════

# URL de l'API Hono (Cloudflare Worker) — en dev local, port 5173
# En prod : https://paiecashfan.com (même domaine, pas besoin de var)
VITE_API_BASE=http://localhost:5173

# (optionnel) URL du marketplace si jamais on linke depuis ici
VITE_MARKETPLACE_URL=http://localhost:5174
