# URL du backend Express — en dev local, port 3001
# En prod : laisser vide (même domaine via Vercel rewrites)
VITE_API_BASE=http://localhost:3001

# Supabase (projet : npmenstkeahngrzemmna)
# → Dashboard Supabase → Settings → API
VITE_SUPABASE_URL=https://npmenstkeahngrzemmna.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon/public key (pas la service_role !)

# (optionnel) URL du marketplace si jamais on linke depuis ici
VITE_MARKETPLACE_URL=http://localhost:5174
